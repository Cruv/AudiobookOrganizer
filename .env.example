# Audiobook Organizer Configuration

# User/Group IDs for file permissions (Docker only)
PUID=1000
PGID=1000

# Timezone
TZ=America/New_York

# Database path (Docker default: /app/data/audiobook_organizer.db)
DATABASE_URL=sqlite:///./data/audiobook_organizer.db

# Google Books API key (optional, improves online lookup)
GOOGLE_BOOKS_API_KEY=

# Default output settings (can also be changed in the web UI)
DEFAULT_OUTPUT_PATTERN={Author}/{Series}/{SeriesPosition} - {Title} ({Year})
DEFAULT_OUTPUT_ROOT=/organized
